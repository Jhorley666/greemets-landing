---
// Hero.astro
---

<section class="hero-section" id="inicio">
  <!-- Background with overlay -->
  <div class="hero-bg-container" style={`background-image: url('${import.meta.env.BASE_URL}/img/hero.jpg');`}>
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content">
    <div class="hero-text-block">
      <h1 class="hero-title reveal">
        Medimos lo que realmente importa para construir un <span class="accent-serif">futuro sostenible</span>
      </h1>
      <p class="hero-subtitle reveal" style="transition-delay: 0.2s;">
        Especialistas en descarbonización, medición de huella ecológica, seguridad industrial, análisis de riesgos, consultoría y certificación ambiental integral.
      </p>
      
      <div class="hero-actions reveal" style="transition-delay: 0.4s;">
        <a href="#contacto" class="btn btn-accent btn-hero">Hablar con un experto</a>
        <a href="#servicios" class="btn btn-secondary btn-hero-secondary">Ver Servicios</a>
      </div>
    </div>
  </div>

  <!-- Scroll Down Indicator (Positioned safely below CTAs) -->
  <div class="scroll-indicator-container">
    <a href="#sobre-nosotros" aria-label="Desplazarse hacia abajo" class="scroll-indicator">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <polyline points="19 12 12 19 5 12"></polyline>
      </svg>
      <span class="scroll-text">Descubrir</span>
    </a>
  </div>

</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-light);
    overflow: hidden;
    padding-top: 6rem;
    padding-bottom: 8rem;
    z-index: 0; /* Establish stacking context */
  }

  .hero-bg-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    z-index: 1;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      180deg,
      rgba(10, 61, 42, 0.8) 0%,
      rgba(10, 61, 42, 0.9) 60%,
      rgba(10, 61, 42, 0.95) 100%
    );
    z-index: 2;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    z-index: 10;
  }

  .hero-text-block {
    max-width: 850px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-title {
    color: var(--bone);
    font-size: clamp(2rem, 6vw, 4rem);
    margin-bottom: var(--spacing-md);
    line-height: 1.15;
    font-weight: 700;
  }

  .accent-serif {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--accent);
    font-weight: 400;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    color: var(--sage-light);
    margin-bottom: var(--spacing-lg);
    line-height: 1.5;
    font-weight: 400;
    max-width: 600px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    justify-content: center;
    width: 100%;
  }

  .btn-hero {
    box-shadow: 0 4px 20px oklch(82% 0.11 82 / 30%);
  }

  .btn-hero-secondary {
    border-color: rgba(255, 255, 255, 0.4);
    color: var(--bone);
  }

  .btn-hero-secondary:hover {
    border-color: var(--bone);
    background-color: rgba(255, 255, 255, 0.1);
  }

  /* Scroll Indicator Container */
  .scroll-indicator-container {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--sage-light);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0.8;
    transition: opacity var(--transition-fast), color var(--transition-fast);
    animation: hero-bounce 2s ease infinite;
  }

  .scroll-indicator:hover {
    opacity: 1;
    color: var(--accent);
  }

  .scroll-text {
    font-family: var(--font-sans);
  }

  @keyframes hero-bounce {
    0%, 20%, 50%, 80%, 100% {
      transform: translateY(0);
    }
    40% {
      transform: translateY(-8px);
    }
    60% {
      transform: translateY(-4px);
    }
  }

  @media (max-height: 700px) {
    .hero-section {
      min-height: auto;
      padding-bottom: 6rem;
    }
    .scroll-indicator-container {
      display: none;
    }
  }
</style>