---
import { Mail, Phone, MapPin, Send } from '@lucide/astro';
---

<section class="section contact-section" id="contacto">
  <div class="container">
    <div class="contact-grid">
      <!-- Info Column -->
      <div class="contact-info-col reveal">
        <span class="section-tag">Contacto</span>
        <h2 class="contact-title">¿Listo para dar el <span class="accent-title">siguiente paso</span>?</h2>
        <p class="contact-desc">
          Contáctenos hoy mismo para recibir un diagnóstico preliminar sin compromiso. Nuestro equipo de ingenieros está listo para diseñar la solución ambiental ideal para su empresa.
        </p>

        <div class="contact-methods">
          <div class="contact-method-item">
            <div class="method-icon-box">
              <MapPin class="method-icon" />
            </div>
            <div class="method-text">
              <h3>Ubicación</h3>
              <p>Telmo Heredia y Elisa Mariño</p>
              <p>San Juan de Cumbayá, Quito - Ecuador</p>
            </div>
          </div>

          <div class="contact-method-item">
            <div class="method-icon-box">
              <Phone class="method-icon" />
            </div>
            <div class="method-text">
              <h3>Teléfonos</h3>
              <p><a href="tel:+593987889700">+593 987 889 700</a></p>
            </div>
          </div>

          <div class="contact-method-item">
            <div class="method-icon-box">
              <Mail class="method-icon" />
            </div>
            <div class="method-text">
              <h3>Correo Electrónico</h3>
              <p><a href="mailto:gerencia@greemets.com">gerencia@greemets.com</a></p>
            </div>
          </div>
        </div>
      </div>

      <!-- Form Column -->
      <div class="contact-form-col reveal" style="transition-delay: 0.2s;">
        <form class="contact-form glass" id="contact-form-el" novalidate>
          <!-- Web3Forms Access Key (User can configure it later) -->
          <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
          <input type="hidden" name="subject" value="Nuevo contacto desde sitio web GREEMETS" />
          <input type="checkbox" name="botcheck" class="bot-check" style="display: none;" />

          <div class="form-group">
            <label for="form-name">Nombre Completo *</label>
            <input type="text" id="form-name" name="name" required placeholder="Ej. Ing. Juan Pérez" />
            <span class="error-msg" id="error-name">El nombre es obligatorio.</span>
          </div>

          <div class="form-group">
            <label for="form-company">Empresa / Organización *</label>
            <input type="text" id="form-company" name="company" required placeholder="Ej. Industrias del Sur" />
            <span class="error-msg" id="error-company">La empresa es obligatoria.</span>
          </div>

          <div class="form-grid">
            <div class="form-group">
              <label for="form-email">Email Corporativo *</label>
              <input type="email" id="form-email" name="email" required placeholder="juan.perez@empresa.com" />
              <span class="error-msg" id="error-email">Ingrese un correo válido.</span>
            </div>

            <div class="form-group">
              <label for="form-phone">Teléfono de Contacto (Formato Ec) *</label>
              <div class="phone-input-wrapper">
                <span class="phone-prefix">+593</span>
                <input type="tel" id="form-phone" name="phone" required placeholder="987654321" />
              </div>
              <span class="error-msg" id="error-phone">Ingrese un celular de 9 dígitos o fijo de 8 dígitos (sin el +593).</span>
            </div>
          </div>

          <div class="form-group">
            <label for="form-message">Mensaje / Requerimiento *</label>
            <textarea id="form-message" name="message" rows="5" required placeholder="Describa brevemente los servicios de su interés..."></textarea>
            <span class="error-msg" id="error-message">El mensaje no puede estar vacío.</span>
          </div>

          <button type="submit" class="btn btn-primary form-submit-btn">
            Enviar Mensaje
            <Send class="btn-icon" />
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    background-color: var(--cream);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-lg);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .contact-grid {
      grid-template-columns: 4.5fr 5.5fr;
      gap: var(--spacing-xl);
    }
  }

  .contact-title {
    margin-bottom: var(--spacing-md);
  }

  .accent-title {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--forest);
    font-weight: 400;
  }

  .contact-desc {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--spacing-lg);
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .contact-method-item {
    display: flex;
    gap: var(--spacing-sm);
    align-items: flex-start;
  }

  .method-icon-box {
    width: 2.8rem;
    height: 2.8rem;
    border-radius: var(--radius-sm);
    background-color: var(--sage-light);
    color: var(--forest);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  :global(.method-icon) {
    width: 1.4rem;
    height: 1.4rem;
  }

  .method-text h3 {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    color: var(--forest-deep);
    margin-bottom: 0.2rem;
  }

  .method-text p {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 0;
    line-height: 1.4;
  }

  .method-text a:hover {
    color: var(--forest);
    text-decoration: underline;
  }

  /* Form Styling */
  .contact-form {
    padding: 2rem 1.5rem;
    border-radius: var(--radius-lg);
    background: var(--bone);
    border: 1px solid var(--sand);
    box-shadow: var(--shadow-md);
  }

  @media (min-width: 768px) {
    .contact-form {
      padding: 2.5rem;
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-sm);
    }
  }

  label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--forest-deep);
  }

  input[type="text"],
  input[type="email"],
  input[type="tel"],
  textarea {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    padding: 0.8rem 1rem;
    border: 1.5px solid var(--sand);
    border-radius: var(--radius-sm);
    background-color: var(--bone);
    color: var(--text-dark);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    outline: none;
    width: 100%;
  }

  input:focus,
  textarea:focus {
    border-color: var(--forest);
    box-shadow: 0 0 0 3px oklch(35% 0.07 162 / 12%);
  }

  /* Phone input with country code block */
  .phone-input-wrapper {
    display: flex;
    align-items: center;
    border: 1.5px solid var(--sand);
    border-radius: var(--radius-sm);
    background-color: var(--bone);
    overflow: hidden;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .phone-input-wrapper:focus-within {
    border-color: var(--forest);
    box-shadow: 0 0 0 3px oklch(35% 0.07 162 / 12%);
  }

  .phone-prefix {
    background-color: oklch(0% 0 0 / 4%);
    padding: 0.8rem 0.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-muted);
    border-right: 1.5px solid var(--sand);
  }

  .phone-input-wrapper input {
    border: none;
    padding: 0.8rem 1rem;
  }

  .phone-input-wrapper input:focus {
    box-shadow: none;
  }

  /* Error messages */
  .error-msg {
    font-size: 0.78rem;
    color: var(--error);
    display: none;
    margin-top: -0.2rem;
  }

  input.invalid,
  textarea.invalid,
  .phone-input-wrapper.invalid {
    border-color: var(--error);
  }

  input.invalid + .error-msg,
  textarea.invalid + .error-msg,
  .phone-input-wrapper.invalid + .error-msg {
    display: block;
  }

  .form-submit-btn {
    width: 100%;
    margin-top: 0.5rem;
  }

  :global(.btn-icon) {
    width: 1.1rem;
    height: 1.1rem;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form-el') as HTMLFormElement | null;
    if (!form) return;

    const nameInput = document.getElementById('form-name') as HTMLInputElement;
    const companyInput = document.getElementById('form-company') as HTMLInputElement;
    const emailInput = document.getElementById('form-email') as HTMLInputElement;
    const phoneInput = document.getElementById('form-phone') as HTMLInputElement;
    const phoneWrapper = phoneInput.closest('.phone-input-wrapper');
    const messageInput = document.getElementById('form-message') as HTMLTextAreaElement;

    // Standard fields list for easy loops
    const fields = [
      { el: nameInput, errorId: 'error-name', validator: (v: string) => v.trim() !== '' },
      { el: companyInput, errorId: 'error-company', validator: (v: string) => v.trim() !== '' },
      { el: emailInput, errorId: 'error-email', validator: (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) },
      { el: messageInput, errorId: 'error-message', validator: (v: string) => v.trim() !== '' },
    ];

    // Phone validation custom
    const validatePhone = (value: string) => {
      // Ecuador cellular: 9XXXXXXXX (9 digits), fixed: 2XXXXXXX to 7XXXXXXX (8 digits)
      const cleaned = value.replace(/\s+/g, '');
      return /^[9]\d{8}$/.test(cleaned) || /^[2-7]\d{7}$/.test(cleaned);
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      let isValid = true;

      // 1. Validate normal fields
      fields.forEach(field => {
        const value = field.el.value;
        const fieldIsValid = field.validator(value);
        
        if (!fieldIsValid) {
          field.el.classList.add('invalid');
          isValid = false;
        } else {
          field.el.classList.remove('invalid');
        }
      });

      // 2. Validate phone field
      if (!validatePhone(phoneInput.value)) {
        phoneWrapper?.classList.add('invalid');
        const phoneError = document.getElementById('error-phone');
        if (phoneError) phoneError.style.display = 'block';
        isValid = false;
      } else {
        phoneWrapper?.classList.remove('invalid');
        const phoneError = document.getElementById('error-phone');
        if (phoneError) phoneError.style.display = 'none';
      }

      if (!isValid) {
        window.showToast('Por favor, complete correctamente los campos requeridos.', 'error');
        return;
      }

      // Submit logic
      const submitBtn = form.querySelector('.form-submit-btn') as HTMLButtonElement;
      const originalBtnHtml = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = 'Enviando...';

      const formData = new FormData(form);
      // Append country prefix to phone value before sending
      formData.set('phone', `+593 ${phoneInput.value}`);

      const accessKey = formData.get('access_key');
      
      try {
        if (accessKey === 'YOUR_ACCESS_KEY_HERE') {
          // Simulation mode for demo
          await new Promise(resolve => setTimeout(resolve, 1500));
          window.showToast('¡Mensaje enviado con éxito! Nos contactaremos pronto.', 'success');
          form.reset();
        } else {
          // Actual submission to Web3Forms
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            body: formData
          });
          const data = await response.json();
          if (data.success) {
            window.showToast('¡Mensaje enviado con éxito! Nos contactaremos pronto.', 'success');
            form.reset();
          } else {
            throw new Error(data.message || 'Error al enviar');
          }
        }
      } catch (err: any) {
        console.error(err);
        window.showToast(err.message || 'Hubo un error al enviar el formulario. Intente de nuevo.', 'error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalBtnHtml;
      }
    });

    // Remove invalid outline on input focus / keyup
    fields.forEach(field => {
      field.el.addEventListener('input', () => {
        if (field.validator(field.el.value)) {
          field.el.classList.remove('invalid');
        }
      });
    });

    phoneInput.addEventListener('input', () => {
      if (validatePhone(phoneInput.value)) {
        phoneWrapper?.classList.remove('invalid');
        const phoneError = document.getElementById('error-phone');
        if (phoneError) phoneError.style.display = 'none';
      }
    });
  });
</script>
