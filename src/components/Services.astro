---
import { Leaf, Wind, LineChart, ShieldCheck } from '@lucide/astro';

// Services list
const services = [
  {
    id: 1,
    title: "Análisis de Riesgos Laborales",
    description:
      "Protegemos lo más importante de su organización: su gente y sus operaciones mediante servicios especializados en análisis de riesgos laborales y evaluación de la infraestructura de los sistemas de gestión en seguridad industrial.",
    details:
      "Identificamos peligros, minimizamos riesgos y fortalecemos la prevención para garantizar entornos de trabajo seguros, eficientes y en cumplimiento con la normativa vigente.",
    icon: ShieldCheck,
    image: "/img/20161020_094141.jpg",
    featured: true
  },
  {
    id: 2,
    title: "Mitigación de Emisiones de Metano",
    description:
      "Ayudamos a las empresas del sector de petróleo y gas a reducir sus emisiones de metano mediante la implementación de programas de Detección y Reparación de Fugas (LDAR).",
    details:
      "Aplicamos tecnologías avanzadas para identificar, cuantificar y gestionar emisiones fugitivas en instalaciones de producción, procesamiento, transporte y almacenamiento de hidrocarburos.",
    icon: Wind,
    image: "/img/20251008_094943.jpg",
    featured: false
  },
  {
    id: 3,
    title: "Huella de Carbono y Plan de Descarbonización",
    description:
      "Acompañamos a las organizaciones en la medición, gestión y reducción de su impacto climático mediante el cálculo de la huella de carbono corporativa y el desarrollo de estrategias de descarbonización.",
    details:
      "Cuantificamos las emisiones de gases de efecto invernadero, identificamos las principales fuentes de emisión y diseñamos planes de acción personalizados para reducirlas de manera eficiente y sostenible. Nuestros servicios permiten fortalecer el desempeño ambiental, cumplir con estándares y compromisos climáticos, y avanzar hacia operaciones más competitivas y bajas en carbono.",
    icon: Leaf,
    image: "/img/IMG_0088.JPG",
    featured: true
  },
  {
    id: 4,
    title: "Consultoría en Eficiencia Energética",
    description:
      "Ayudamos a las organizaciones a optimizar el uso de la energía y reducir sus costos operativos mediante la identificación de oportunidades de mejora en sus procesos e instalaciones.",
    details:
      "Realizamos diagnósticos energéticos, análisis de consumos y evaluación de medidas de eficiencia que permiten incrementar la productividad, disminuir el desperdicio energético y reducir las emisiones asociadas al consumo de energía. Nuestras soluciones fortalecen la competitividad y contribuyen a los objetivos de sostenibilidad y descarbonización.",
    icon: LineChart,
    image: "/img/IMG_0299.JPG",
    featured: false
  }
];
---

<section class="section services-section" id="servicios">
  <div class="container">
    <div class="services-header reveal">
      <span class="section-tag">Nuestros Servicios</span>
      <h2 class="services-title">
        Ingeniería y consultoría especializada de
        <span class="accent-title">alto nivel</span>
      </h2>
      <p class="services-subtitle">
        Ofrecemos soluciones ambientales, energéticas y de seguridad industrial con rigor científico, alineadas con los más altos estándares globales para impulsar la rentabilidad sostenible.
      </p>
    </div>

    <div class="services-grid">
      {services.map(service => {
        const IconComponent = service.icon;
        return (
          <div class={`service-card reveal ${service.featured ? 'card-featured' : ''}`}>
            <div class="service-card-img-wrapper">
              <img
                src={`${import.meta.env.BASE_URL}/${service.image.replace(/^\//, '')}`}
                alt={service.title}
                class="service-card-img"
                loading="lazy"
              />
            </div>

            <div class="card-inner">
              <div class="icon-container">
                <IconComponent class="service-icon" />
              </div>

              <h3 class="service-card-title">{service.title}</h3>

              <p class="service-card-desc">
                {service.description}
              </p>

              <div class="service-card-details">
                <div class="details-divider"></div>
                <p class="details-text">
                  {service.details}
                </p>
              </div>
            </div>

            <div class="card-border-gradient"></div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .services-section {
    background-color: var(--cream);
    position: relative;
  }

  .services-header {
    text-align: center;
    max-width: 750px;
    margin: 0 auto var(--spacing-xl) auto;
  }

  .services-subtitle {
    margin: 0 auto;
    font-size: 1.1rem;
  }

  .section-tag {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--sage);
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .accent-title {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--forest);
    font-weight: 400;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-md);
  }

  .service-card {
    background: var(--bone);
    border-radius: var(--radius-lg);
    padding: 0;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
    display: flex;
    flex-direction: column;
    border: 1px solid oklch(0% 0 0 / 3%);
  }

  .service-card-img-wrapper {
    position: relative;
    width: 100%;
    height: 180px;
    overflow: hidden;
  }

  .service-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .service-card:hover .service-card-img {
    transform: scale(1.08);
  }

  .service-card-img-wrapper::after {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 40%;
    background: linear-gradient(to top, var(--bone), transparent);
  }

  .card-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--spacing-md);
    z-index: 2;
  }

  .icon-container {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: var(--radius-md);
    background: var(--sage-light);
    color: var(--forest);
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: var(--spacing-md);
    transition: .3s;
  }

  :global(.service-icon) {
    width: 1.8rem;
    height: 1.8rem;
    stroke-width: 1.8;
  }

  .service-card-title {
    font-size: 1.25rem;
    color: var(--forest-deep);
    margin-bottom: .75rem;
  }

  .service-card-desc {
    font-size: .95rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .service-card-details {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: .3s;
  }

  .details-divider {
    height: 1px;
    background: oklch(0% 0 0 / 8%);
    margin: 1rem 0;
  }

  .details-text {
    font-size: .88rem;
    color: var(--forest-deep);
    line-height: 1.5;
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }

  .service-card:hover .icon-container {
    background: var(--forest);
    color: var(--accent);
    transform: scale(1.05) rotate(5deg);
  }

  .service-card:hover .service-card-details {
    max-height: 220px;
    opacity: 1;
    margin-top: .5rem;
  }

  .card-border-gradient {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-lg);
    border: 2px solid transparent;
    background: linear-gradient(135deg, var(--sage), var(--accent)) border-box;
    mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: .3s;
    pointer-events: none;
  }

  .service-card:hover .card-border-gradient {
    opacity: 1;
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-lg);
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .card-featured {
      grid-column: span 2;
    }

    .card-featured .card-inner {
      display: grid;
      grid-template-columns: 80px 1fr;
      grid-template-rows: auto auto;
      column-gap: var(--spacing-md);
    }

    .card-featured .icon-container {
      grid-row: span 2;
      margin-bottom: 0;
    }

    .card-featured .service-card-title {
      grid-column: 2;
      font-size: 1.4rem;
    }

    .card-featured .service-card-desc,
    .card-featured .service-card-details {
      grid-column: 2;
    }
  }
</style>