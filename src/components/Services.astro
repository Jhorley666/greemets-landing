---
import { Leaf, Award, Droplet, Wind, LineChart, ShieldCheck, ClipboardCheck } from '@lucide/astro';

// Services list
const services = [
  {
    id: 1,
    title: "Cálculo de Huella de Carbono, Hídrica y Descarbonización",
    description: "Medición cuantitativa precisa de las huellas de carbono (CO₂) e hídrica (H₂O) de su organización, productos o eventos, junto con planes integrales de mitigación y descarbonización.",
    details: "Implementamos las directrices del GHG Protocol, ISO 14064 e ISO 14046. Identificamos puntos críticos de emisión en su cadena de valor y diseñamos un plan de transición energética y eficiencia para reducir costos operativos y mitigar impactos.",
    icon: Leaf,
    featured: true
  },
  {
    id: 2,
    title: "Certificación de Huellas de Carbono",
    description: "Soporte técnico y auditoría para la certificación formal de su huella de carbono, validando la veracidad de sus esfuerzos ante reguladores y mercados internacionales.",
    details: "Le acompañamos durante todo el proceso de verificación por parte de organismos de certificación acreditados. Aseguramos que la declaración de conformidad cumpla con los estándares más estrictos, otorgándole un sello verde confiable.",
    icon: Award,
    featured: false
  },
  {
    id: 3,
    title: "Certificación de Huella Hídrica",
    description: "Acompañamiento especializado para obtener certificaciones oficiales en la gestión del agua y el uso eficiente del recurso hídrico corporativo.",
    details: "Validamos su inventario de huella hídrica y sus planes de neutralidad hídrica o eficiencia en base a la norma ISO 14046. Obtenga una ventaja competitiva demostrando un uso transparente y responsable del agua.",
    icon: Droplet,
    featured: false
  },
  {
    id: 4,
    title: "Verificación de Emisiones de Metano",
    description: "Detección, cuantificación y verificación independiente de emisiones fugitivas de metano (CH₄) en sectores industriales y energéticos.",
    details: "El metano tiene un potencial de calentamiento global hasta 28 veces superior al CO₂. Proveemos verificación experta para asegurar el reporte preciso y la efectividad de sus programas de control de fugas (LDAR).",
    icon: Wind,
    featured: false
  },
  {
    id: 5,
    title: "Consultoría de Línea Base de Emisiones de Metano",
    description: "Estudios diagnósticos para establecer la línea base de emisiones de metano en sus instalaciones y definir estrategias realistas de mitigación.",
    details: "Determinamos la línea de partida cuantitativa de las fuentes emisoras de metano en sus operaciones. Desarrollamos planes de acción para implementar mejores prácticas operativas y tecnologías de bajas emisiones.",
    icon: LineChart,
    featured: false
  },
  {
    id: 6,
    title: "Consultoría en Seguridad Industrial y Salud Ocupacional",
    description: "Diseño y estructuración de planes de prevención de riesgos laborales, salud ocupacional y cumplimiento de la legislación de seguridad industrial.",
    details: "Evaluamos los riesgos laborales de sus operaciones y estructuramos reglamentos internos de higiene y seguridad, planes de emergencia, capacitación a brigadas y seguimiento médico ocupacional preventivo.",
    icon: ShieldCheck,
    featured: false
  },
  {
    id: 7,
    title: "Sistemas de Gestión ISO (9001, 14001, 45001, 50001)",
    description: "Asesoría para el levantamiento, auditoría interna e implementación de sistemas integrados de gestión bajo estándares de calidad, ambiente, seguridad y energía.",
    details: "Diseñamos sistemas prácticos e integrados que optimizan procesos: Calidad (ISO 9001), Gestión Ambiental (ISO 14001), Seguridad y Salud Ocupacional (ISO 45001) y Eficiencia Energética (ISO 50001).",
    icon: ClipboardCheck,
    featured: true
  }
];
---

<section class="section services-section" id="servicios">
  <div class="container">
    <div class="services-header reveal">
      <span class="section-tag">Nuestros Servicios</span>
      <h2 class="services-title">Ingeniería y consultoría especializada de <span class="accent-title">alto nivel</span></h2>
      <p class="services-subtitle">
        Ofrecemos soluciones ambientales, energéticas y de seguridad industrial con rigor científico, alineadas con los más altos estándares globales para impulsar la rentabilidad sostenible.
      </p>
    </div>

    <!-- Asymmetric Grid System -->
    <div class="services-grid">
      {services.map(service => {
        const IconComponent = service.icon;
        return (
          <div class={`service-card reveal ${service.featured ? 'card-featured' : ''}`}>
            <div class="card-inner">
              <div class="icon-container">
                <IconComponent class="service-icon" />
              </div>
              <h3 class="service-card-title">{service.title}</h3>
              <p class="service-card-desc">{service.description}</p>
              
              <!-- Hover Extended Details -->
              <div class="service-card-details">
                <div class="details-divider"></div>
                <p class="details-text">{service.details}</p>
              </div>
            </div>
            <div class="card-border-gradient"></div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .services-section {
    background-color: var(--cream);
    position: relative;
  }

  .services-header {
    text-align: center;
    max-width: 750px;
    margin: 0 auto var(--spacing-xl) auto;
  }

  .services-subtitle {
    margin: 0 auto;
    font-size: 1.1rem;
  }

  .section-tag {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--sage);
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .accent-title {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--forest);
    font-weight: 400;
  }

  /* Asymmetric Masonry-Like CSS Grid */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-md);
  }

  /* Service Card styling */
  .service-card {
    background: var(--bone);
    border-radius: var(--radius-lg);
    padding: var(--spacing-md);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
    cursor: default;
    display: flex;
    flex-direction: column;
    z-index: 1;
    border: 1px solid oklch(0% 0 0 / 3%);
  }

  .card-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    z-index: 5;
  }

  .icon-container {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: var(--radius-md);
    background-color: var(--sage-light);
    color: var(--forest);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--spacing-md);
    transition: transform var(--transition-normal), background-color var(--transition-normal), color var(--transition-normal);
  }

  /* Adjust icon sizing */
  :global(.service-icon) {
    width: 1.8rem;
    height: 1.8rem;
    stroke-width: 1.8;
  }

  .service-card-title {
    font-size: 1.25rem;
    color: var(--forest-deep);
    margin-bottom: 0.75rem;
    transition: color var(--transition-fast);
  }

  .service-card-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0;
    transition: opacity var(--transition-fast);
  }

  /* Details container - hidden by default, expands on hover */
  .service-card-details {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height var(--transition-normal), opacity var(--transition-normal);
  }

  .details-divider {
    height: 1px;
    background-color: oklch(0% 0 0 / 8%);
    margin: 1rem 0;
  }

  .details-text {
    font-size: 0.88rem;
    color: var(--forest-deep);
    line-height: 1.5;
    margin-bottom: 0;
  }

  /* Hover States */
  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }

  .service-card:hover .icon-container {
    background-color: var(--forest);
    color: var(--accent);
    transform: scale(1.05) rotate(5deg);
  }

  .service-card:hover .service-card-title {
    color: var(--forest);
  }

  .service-card:hover .service-card-details {
    max-height: 200px;
    opacity: 1;
    margin-top: 0.5rem;
  }

  /* Gradient glow border effect */
  .card-border-gradient {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-lg);
    border: 2px solid transparent;
    background: linear-gradient(135deg, var(--sage) 0%, var(--accent) 100%) border-box;
    mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity var(--transition-normal);
    z-index: 2;
    pointer-events: none;
  }

  .service-card:hover .card-border-gradient {
    opacity: 1;
  }

  /* Desktop Grid Asymmetry Settings */
  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-lg);
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    /* Asymmetric sizing on desktop */
    .card-featured {
      grid-column: span 2;
    }
    
    .card-featured .card-inner {
      display: grid;
      grid-template-columns: 80px 1fr;
      grid-template-rows: auto auto;
      column-gap: var(--spacing-md);
    }

    .card-featured .icon-container {
      grid-row: span 2;
      align-self: start;
      margin-bottom: 0;
    }

    .card-featured .service-card-title {
      grid-column: 2;
      align-self: center;
      margin-bottom: 0.5rem;
      font-size: 1.4rem;
    }

    .card-featured .service-card-desc {
      grid-column: 2;
      font-size: 1rem;
    }

    .card-featured .service-card-details {
      grid-column: 2;
    }
  }
</style>
