---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Green Metrics Solutions (GREEMETS) — Consultoría e Ingeniería Ambiental", 
  description = "Servicios premium de cálculo de huella de carbono e hídrica, descarbonización, certificación, seguridad industrial y sistemas de gestión ISO 9001, 14001, 45001 y 50001 en Ecuador." 
} = Astro.props;

const siteUrl = "https://greemets.github.io"; // Adjust as needed
const base = import.meta.env.BASE_URL;
const ogImage = `${siteUrl}${base}img/nature.jpg`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Green Metrics Solutions (GREEMETS)" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={siteUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Fonts Link Preload for Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">

    <!-- Schema.json Structured Metadata (JSON-LD) -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Green Metrics Solutions GREEMETS",
        "alternateName": "GREEMETS",
        "url": "https://greemets.github.io",
        "logo": "https://greemets.github.io/favicon.svg",
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+593-900-000-000",
          "contactType": "customer service",
          "areaServed": "EC",
          "availableLanguage": "Spanish"
        },
        "sameAs": [
          "https://www.linkedin.com/company/greemets"
        ]
      }
    </script>
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Green Metrics Solutions GREEMETS",
        "image": "https://greemets.github.io/img/nature.jpg",
        "@id": "https://greemets.github.io/#localbusiness",
        "url": "https://greemets.github.io",
        "telephone": "+593-900-000-000",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Av. de los Granados y Av. Eloy Alfaro",
          "addressLocality": "Quito",
          "addressRegion": "Pichincha",
          "postalCode": "170513",
          "addressCountry": "EC"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": -0.165,
          "longitude": -78.47
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday"
          ],
          "opens": "08:30",
          "closes": "17:30"
        }
      }
    </script>
  </head>
  <body>
    <!-- Toast container for feedback notifications -->
    <div id="toast-container" class="toast-container" aria-live="polite"></div>

    <!-- Main Content -->
    <slot />

    <!-- Scroll Reveal JavaScript -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const reveals = document.querySelectorAll('.reveal');
        
        const revealOnScroll = () => {
          const windowHeight = window.innerHeight;
          reveals.forEach(element => {
            const elementTop = element.getBoundingClientRect().top;
            const elementVisible = 100; // Trigger distance in pixels
            
            if (elementTop < windowHeight - elementVisible) {
              element.classList.add('active');
            }
          });
        };

        window.addEventListener('scroll', revealOnScroll);
        // Initial run to show elements already in viewport
        revealOnScroll();
      });
      
      // Toast notification helper function (attached to window for use in other files)
      window.showToast = function(message, type = 'success') {
        const container = document.getElementById('toast-container');
        if (!container) return;

        const toast = document.createElement('div');
        toast.className = `toast toast-${type}`;
        
        let iconHtml = '';
        if (type === 'success') {
          iconHtml = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
        } else {
          iconHtml = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>`;
        }
        
        toast.innerHTML = `
          ${iconHtml}
          <span>${message}</span>
        `;
        
        container.appendChild(toast);
        
        // Remove toast after 4 seconds
        setTimeout(() => {
          toast.style.opacity = '0';
          toast.style.transform = 'translateY(10px) scale(0.95)';
          toast.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
          setTimeout(() => {
            if (toast.parentNode) {
              container.removeChild(toast);
            }
          }, 300);
        }, 4000);
      };
    </script>
  </body>
</html>
